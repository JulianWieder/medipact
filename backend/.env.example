SECRET_KEY=dein-sicherer-zufallsstring-hier
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PRODUCTION=true

APP_BASE_URL=https://medipact.de
CORS_ORIGINS=https://medipact.de,https://www.medipact.de

SMTP_HOST=mail.mandexis.de
SMTP_PORT=587
SMTP_USER=noreply@medipact.de
SMTP_PASSWORD=dein-mailbox-passwort
EMAIL_FROM=medipact <noreply@medipact.de>

DB_PATH=/data/medipact.db

# PayPal-Zahlungen (Orders API v2). PAYPAL_ENV=sandbox zum Testen ohne echtes
# Geld; auf "live" stellen + echte Zugangsdaten aus dem PayPal-Business-Konto
# eintragen, sobald scharf geschaltet werden soll.
PAYPAL_CLIENT_ID=dein-paypal-client-id
PAYPAL_CLIENT_SECRET=dein-paypal-client-secret
PAYPAL_ENV=sandbox
PRICE_PER_PARTICIPANT_EUR=499
